    static void RegisterUserCommand(string name, string folderPath)
    {
        // replace or add
        BuiltInCommands[name] = async args =>
        {
            try
            {
                if (!Directory.Exists(folderPath)) { Console.WriteLine("Command folder missing: " + folderPath); await Task.CompletedTask; return; }
                var script = FindRunScriptInFolder(folderPath);
                if (script == null) { Console.WriteLine("No runnable script found in command folder: " + folderPath); await Task.CompletedTask; return; }

                string JoinArgs(string[] a)
                {
                    if (a == null || a.Length == 0) return string.Empty;
                    return string.Join(' ', a.Select(s => QuoteArg(s)));
                }

                var argstr = JoinArgs(args);
                var isWin = RuntimeInformation.IsOSPlatform(OSPlatform.Windows);
                string cmd;
                var ext = Path.GetExtension(script).ToLowerInvariant();
                if (isWin)
                {
                    if (ext == ".ps1") cmd = $"powershell -NoProfile -ExecutionPolicy Bypass -File {QuoteArg(script)} {argstr}";
                    else cmd = QuoteArg(script) + (string.IsNullOrEmpty(argstr) ? string.Empty : " " + argstr);
                }
                else
                {
                    // rely on shebang or shell to run; ensure path is quoted
                    cmd = QuoteArg(script) + (string.IsNullOrEmpty(argstr) ? string.Empty : " " + argstr);
                }

                await RunExternalAsync(cmd);
