                                        }
                                    }
                                    catch { }
                                }
                                else
                                {
                                    Console.WriteLine($"{addr} {port}: closed");
                                }
                            }
                            catch (Exception ex)
                            {
                                Console.WriteLine($"{addr} {port}: error ({ex.Message})");
                            }
                        }
                    }
