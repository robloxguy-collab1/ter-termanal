        // b64 - improved encoder/decoder. Supports AES-GCM encryption with passphrase and optional gzip compression.
        // Usage:
        //   b64 encode [--password <pw>] [--compress] <text>
        //   b64 decode [--password <pw>] <base64>
        BuiltInCommands["b64"] = async args =>
        {
            if (args.Length < 2) { Console.WriteLine("Usage: b64 encode|decode [--password <pw>] [--compress] <text>"); await Task.CompletedTask; return; }
            try
            {
                var list = args.ToList();
                var mode = list[0].ToLowerInvariant();
                string password = null; bool compress = false;
                // parse flags
                for (int i = 1; i < list.Count; i++)
                {
                    if (list[i] == "--password" && i + 1 < list.Count) { password = list[i + 1]; list[i] = null; list[i + 1] = null; i++; }
                    else if (list[i] == "--compress") { compress = true; list[i] = null; }
                }
                var remaining = list.Where(s => !string.IsNullOrEmpty(s)).Skip(1).ToArray();
                if (remaining.Length == 0) { Console.WriteLine("Missing text argument"); await Task.CompletedTask; return; }
                var text = string.Join(' ', remaining);

                byte[] CompressIfNeeded(byte[] input)
                {
                    if (!compress) return input;
                    using var ms = new MemoryStream(); using (var gz = new GZipStream(ms, CompressionLevel.Optimal, true)) { gz.Write(input, 0, input.Length); }
                    return ms.ToArray();
                }

                byte[] DecompressIfNeeded(byte[] input)
                {
                    try
                    {
                        using var inMs = new MemoryStream(input);
                        using var gz = new GZipStream(inMs, CompressionMode.Decompress);
                        using var outMs = new MemoryStream(); gz.CopyTo(outMs); return outMs.ToArray();
                    }
                    catch { return input; }
                }

                if (mode == "encode")
                {
                    var plain = Encoding.UTF8.GetBytes(text);
                    var toEncrypt = CompressIfNeeded(plain);
                    if (string.IsNullOrEmpty(password))
                    {
                        // no password: produce a safe plain marker + base64
                        var header = Encoding.ASCII.GetBytes("PLN");
                        var outb = new byte[header.Length + toEncrypt.Length]; Buffer.BlockCopy(header, 0, outb, 0, header.Length); Buffer.BlockCopy(toEncrypt, 0, outb, header.Length, toEncrypt.Length);
                        Console.WriteLine(Convert.ToBase64String(outb));
                        await Task.CompletedTask; return;
                    }

                    // derive key with PBKDF2 using random salt
                    var salt = new byte[16]; RandomNumberGenerator.Fill(salt);
                    using var kdf = new Rfc2898DeriveBytes(password, salt, 200_000, HashAlgorithmName.SHA256);
                    var key = kdf.GetBytes(32);
                    var nonce = new byte[12]; RandomNumberGenerator.Fill(nonce);
                    var cipher = new byte[toEncrypt.Length]; var tag = new byte[16];
                    try
                    {
                        using var aesg = new AesGcm(key);
                        aesg.Encrypt(nonce, toEncrypt, cipher, tag);
                    }
                    finally { Array.Clear(key); }

                    // blob = header("AG1") + salt(16) + nonce(12) + tag(16) + cipher
                    using var outStream = new MemoryStream();
                    outStream.Write(Encoding.ASCII.GetBytes("AG1"), 0, 3);
                    outStream.Write(salt, 0, salt.Length);
                    outStream.Write(nonce, 0, nonce.Length);
                    outStream.Write(tag, 0, tag.Length);
                    outStream.Write(cipher, 0, cipher.Length);
                    Console.WriteLine(Convert.ToBase64String(outStream.ToArray()));
                    await Task.CompletedTask; return;
                }
                else if (mode == "decode")
                {
                    byte[] blob;
                    try { blob = Convert.FromBase64String(text); }
                    catch { Console.WriteLine("Invalid base64 input"); await Task.CompletedTask; return; }
                    if (blob.Length < 3) { Console.WriteLine("Invalid input"); await Task.CompletedTask; return; }
                    var hdr = Encoding.ASCII.GetString(blob, 0, 3);
                    if (hdr == "PLN")
                    {
                        var data = new byte[blob.Length - 3]; Buffer.BlockCopy(blob, 3, data, 0, data.Length);
                        var dec = DecompressIfNeeded(data);
                        Console.WriteLine(Encoding.UTF8.GetString(dec)); await Task.CompletedTask; return;
                    }
                    else if (hdr == "AG1")
                    {
                        // parse salt, nonce, tag
                        if (blob.Length < 3 + 16 + 12 + 16) { Console.WriteLine("Invalid encrypted blob"); await Task.CompletedTask; return; }
                        var pos = 3;
                        var salt = new byte[16]; Buffer.BlockCopy(blob, pos, salt, 0, 16); pos += 16;
                        var nonce = new byte[12]; Buffer.BlockCopy(blob, pos, nonce, 0, 12); pos += 12;
                        var tag = new byte[16]; Buffer.BlockCopy(blob, pos, tag, 0, 16); pos += 16;
                        var cipher = new byte[blob.Length - pos]; Buffer.BlockCopy(blob, pos, cipher, 0, cipher.Length);

                        if (string.IsNullOrEmpty(password))
                        {
                            Console.Write("Password: "); password = Console.ReadLine();
                        }

                        using var kdf = new Rfc2898DeriveBytes(password, salt, 200_000, HashAlgorithmName.SHA256);
                        var key = kdf.GetBytes(32);
                        var plain = new byte[cipher.Length];
                        try
                        {
                            using var aesg = new AesGcm(key);
                            aesg.Decrypt(nonce, cipher, tag, plain);
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine("Decryption failed: " + ex.Message); await Task.CompletedTask; return;
                        }
                        finally { Array.Clear(key); }

                        var dec = DecompressIfNeeded(plain);
                        Console.WriteLine(Encoding.UTF8.GetString(dec)); await Task.CompletedTask; return;
                    }
                    else { Console.WriteLine("Unknown input format"); await Task.CompletedTask; return; }
                }
                else Console.WriteLine("Usage: b64 encode|decode [--password <pw>] [--compress] <text>");
            }
            catch (Exception ex) { Console.WriteLine("b64 error: " + ex.Message); }
            await Task.CompletedTask;
        };

