    // Try multiple fallbacks to resolve a friendly machine name for an IP: reverse DNS, NetBIOS (nbtstat/nmblookup), mDNS (avahi-resolve), host/dig.
    static async Task<string> ResolveFriendlyNameAsync(string ip)
    {
        try
        {
            // reverse DNS
            try
            {
                var he = await Dns.GetHostEntryAsync(ip);
                if (!string.IsNullOrEmpty(he?.HostName)) return he.HostName;
            }
            catch { }

            // NetBIOS via external tools
            if (RuntimeInformation.IsOSPlatform(OSPlatform.Windows))
            {
                var outp = await RunProcessCaptureOutputAsync("nbtstat", "-A " + ip, 2000);
                if (!string.IsNullOrEmpty(outp))
                {
                    foreach (var line in outp.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries))
                    {
                        var l = line.Trim();
                        if (l.Contains("<00>") || l.Contains("<20>"))
                        {
                            var idx = l.IndexOf('<');
                            if (idx > 0)
                            {
                                var name = l.Substring(0, idx).Trim();
                                if (!string.IsNullOrEmpty(name) && !name.Equals("WORKGROUP", StringComparison.OrdinalIgnoreCase)) return name;
                            }
                        }
                    }
                }
            }
            else
            {
                var outp = await RunProcessCaptureOutputAsync("nmblookup", $"-A {ip}", 2000);
                if (!string.IsNullOrEmpty(outp))
                {
                    foreach (var line in outp.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries))
                    {
                        var l = line.Trim();
                        if (l.Contains("<00>") || l.Contains("<20>"))
                        {
                            var idx = l.IndexOf('<');
                            if (idx > 0)
                            {
                                var name = l.Substring(0, idx).Trim();
                                if (!string.IsNullOrEmpty(name) && !name.Equals("WORKGROUP", StringComparison.OrdinalIgnoreCase)) return name;
                            }
                        }
                    }
                }

                // avahi resolve (mDNS) - may return 'hostname.local\taddress'
                var av = await RunProcessCaptureOutputAsync("avahi-resolve", $"-a {ip}", 1500);
                if (!string.IsNullOrEmpty(av))
                {
                    var parts = av.Split(new[] { '\t', ' ', '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length >= 1) return parts[0];
                }
            }

            // fallback: host command
            try
            {
                var hostOut = await RunProcessCaptureOutputAsync("host", ip, 1500);
                if (!string.IsNullOrEmpty(hostOut))
                {
                    var m = Regex.Match(hostOut, @"pointer\s+([^\s.]+(?:\.[^\s.]+)*)", RegexOptions.IgnoreCase);
                    if (m.Success) return m.Groups[1].Value.TrimEnd('.');
                    var toks = hostOut.Split(new[] { '\r', '\n', ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
                    if (toks.Length > 0) return toks.Last();
                }
            }
            catch { }
        }
        catch { }
        return null;
    }

