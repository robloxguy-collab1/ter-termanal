                    try
                    {
                        using var h = CreateClient(); using var r = await h.GetAsync($"https://ipinfo.io/{ip}/json");
                        if (r.IsSuccessStatusCode)
                        {
                            var t = await r.Content.ReadAsStringAsync(); using var d = JsonDocument.Parse(t);
                            var root = d.RootElement;
                            if (root.TryGetProperty("loc", out var loc))
                            {
                                var s = loc.GetString(); if (!string.IsNullOrEmpty(s) && s.Contains(','))
                                {
                                    var p = s.Split(','); if (double.TryParse(p[0], out var la) && double.TryParse(p[1], out var lo)) AddCoord(la, lo, "ipinfo", 1.2);
                                }
                            }
