    // User command helpers (class-level so they are visible to InitializeBuiltIns)
    static void LoadUserCommands()
    {
        try
        {
            var root = Path.Combine(CurrentDirectory, "cmdsforter");
            if (!Directory.Exists(root)) return;
            foreach (var d in Directory.GetDirectories(root))
            {
                var name = Path.GetFileName(d);
                if (string.IsNullOrWhiteSpace(name)) continue;
                RegisterUserCommand(name, d);
            }
        }
        catch { }
    }

    static void RegisterUserCommand(string name, string folderPath)
    {
        BuiltInCommands[name] = async args =>
        {
            try
            {
                if (!Directory.Exists(folderPath)) { Console.WriteLine("Command folder missing: " + folderPath); await Task.CompletedTask; return; }
                var script = FindRunScriptInFolder(folderPath);
                if (script == null) { Console.WriteLine("No runnable script found in command folder: " + folderPath); await Task.CompletedTask; return; }

                string JoinArgs(string[] a)
                {
                    if (a == null || a.Length == 0) return string.Empty;
                    return string.Join(' ', a.Select(s => QuoteArg(s)));
                }

                var argstr = JoinArgs(args);
                var isWin = RuntimeInformation.IsOSPlatform(OSPlatform.Windows);
                string cmd;
                var ext = Path.GetExtension(script).ToLowerInvariant();
                if (isWin)
                {
                    if (ext == ".ps1") cmd = $"powershell -NoProfile -ExecutionPolicy Bypass -File {QuoteArg(script)} {argstr}";
                    else cmd = QuoteArg(script) + (string.IsNullOrEmpty(argstr) ? string.Empty : " " + argstr);
                }
                else
                {
                    cmd = QuoteArg(script) + (string.IsNullOrEmpty(argstr) ? string.Empty : " " + argstr);
                }

                await RunExternalAsync(cmd);
            }
            catch (Exception ex) { Console.WriteLine($"{name} error: " + ex.Message); }
            await Task.CompletedTask;
        };
    }

    static string FindRunScriptInFolder(string folder)
    {
        var candidates = new[] { "run", "run.sh", "run.bat", "run.cmd", "run.ps1", "run.exe" };
        foreach (var c in candidates)
        {
            var p = Path.Combine(folder, c);
            if (File.Exists(p)) return p;
        }
        var exts = new[] { ".sh", ".py", ".ps1", ".exe", ".bat", ".cmd" };
        foreach (var f in Directory.GetFiles(folder))
        {
            var e = Path.GetExtension(f).ToLowerInvariant();
            if (exts.Contains(e)) return f;
        }
        return Directory.GetFiles(folder).FirstOrDefault();
    }

    static string QuoteArg(string s)
    {
        if (string.IsNullOrEmpty(s)) return "\"\"";
        if (RuntimeInformation.IsOSPlatform(OSPlatform.Windows))
        {
            if (s.Contains(' ')) return "\"" + s + "\"";
            return s;
        }
        if (!s.Contains('\'')) return "'" + s + "'";
        return '"' + s.Replace("\"", "\\\"") + '"';
    }
    
