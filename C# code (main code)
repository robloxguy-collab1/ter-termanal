                        using var p2 = Process.Start(psi2);
                        if (p2 != null)
                        {
                            var outp2 = await p2.StandardOutput.ReadToEndAsync(); var err2 = await p2.StandardError.ReadToEndAsync(); await p2.WaitForExitAsync();
                            if (!string.IsNullOrWhiteSpace(outp2)) Console.WriteLine(outp2);
                            if (!string.IsNullOrWhiteSpace(err2)) Console.WriteLine(err2);
                            if (p2.ExitCode == 0) { Console.WriteLine("Connected."); await Task.CompletedTask; return; }
                        }

                        // As a last resort when forced, attempt to create an open connection (will only succeed if network accepts no security)
                        if (force)
                        {
                            try
                            {
                                var conName = "temp-" + Guid.NewGuid().ToString("N").Substring(0, 6);
                                var add = new ProcessStartInfo("nmcli", $"connection add type wifi ifname '*' con-name \"{conName}\" ssid \"{ssid}\"") { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false, CreateNoWindow = true };
                                using var padd = Process.Start(add);
                                if (padd != null) { var oa = await padd.StandardOutput.ReadToEndAsync(); var ea = await padd.StandardError.ReadToEndAsync(); await padd.WaitForExitAsync(); if (!string.IsNullOrWhiteSpace(oa)) Console.WriteLine(oa); if (!string.IsNullOrWhiteSpace(ea)) Console.WriteLine(ea); }

                                var mod = new ProcessStartInfo("nmcli", $"connection modify \"{conName}\" wifi-sec.key-mgmt none") { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false, CreateNoWindow = true };
                                using var pmod = Process.Start(mod);
                                if (pmod != null) { var om = await pmod.StandardOutput.ReadToEndAsync(); var em = await pmod.StandardError.ReadToEndAsync(); await pmod.WaitForExitAsync(); if (!string.IsNullOrWhiteSpace(om)) Console.WriteLine(om); if (!string.IsNullOrWhiteSpace(em)) Console.WriteLine(em); }

                                var up = new ProcessStartInfo("nmcli", $"connection up \"{conName}\"") { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false, CreateNoWindow = true };
                                using var pup = Process.Start(up);
                                if (pup != null) { var ou = await pup.StandardOutput.ReadToEndAsync(); var eu = await pup.StandardError.ReadToEndAsync(); await pup.WaitForExitAsync(); if (!string.IsNullOrWhiteSpace(ou)) Console.WriteLine(ou); if (!string.IsNullOrWhiteSpace(eu)) Console.WriteLine(eu); if (pup.ExitCode == 0) { Console.WriteLine("Connected (temporary open profile)"); await Task.CompletedTask; return; } }
                            }
                            catch { }
