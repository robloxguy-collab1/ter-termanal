        // User command extensions: load commands from ./cmdsforter and allow creating new ones
        BuiltInCommands["makecmd"] = async args =>
        {
            if (args.Length == 0) { Console.WriteLine("Usage: makecmd <folder-path> [cmdname]"); await Task.CompletedTask; return; }
            try
            {
                var folder = args[0];
                if (!Path.IsPathRooted(folder)) folder = Path.GetFullPath(Path.Combine(CurrentDirectory, folder));
                if (!Directory.Exists(folder)) { Console.WriteLine("Folder not found: " + folder); await Task.CompletedTask; return; }
                var cmdName = args.Length > 1 ? args[1] : Path.GetFileName(folder.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
                if (string.IsNullOrWhiteSpace(cmdName)) { Console.WriteLine("Invalid command name"); await Task.CompletedTask; return; }
                var destRoot = Path.Combine(CurrentDirectory, "cmdsforter"); Directory.CreateDirectory(destRoot);
                var dest = Path.Combine(destRoot, cmdName);
                if (Directory.Exists(dest))
                {
                    Console.WriteLine($"Command folder already exists at {dest}. Overwrite? (y/N): ");
                    var yn = Console.ReadLine(); if (string.IsNullOrEmpty(yn) || !yn.Trim().StartsWith("y", StringComparison.OrdinalIgnoreCase)) { Console.WriteLine("Aborted."); await Task.CompletedTask; return; }
                    try { Directory.Delete(dest, true); } catch { }
                }
                // copy folder
                CopyDirectory(folder, dest);
                // register in-memory
                RegisterUserCommand(cmdName, dest);
                Console.WriteLine($"Created command '{cmdName}' from {folder} and registered it. Use '{cmdName} [args]' to run.");
            }
            catch (Exception ex) { Console.WriteLine("makecmd error: " + ex.Message); }
            await Task.CompletedTask;
        };

        BuiltInCommands["reload-cmds"] = async args => { LoadUserCommands(); Console.WriteLine("Reloaded user commands from ./cmdsforter"); await Task.CompletedTask; };
        BuiltInCommands["list-cmds"] = async args =>
        {
            try
            {
                var root = Path.Combine(CurrentDirectory, "cmdsforter"); if (!Directory.Exists(root)) { Console.WriteLine("No ./cmdsforter folder found."); await Task.CompletedTask; return; }
                foreach (var d in Directory.GetDirectories(root)) Console.WriteLine(Path.GetFileName(d));
            }
            catch (Exception ex) { Console.WriteLine("list-cmds error: " + ex.Message); }
            await Task.CompletedTask;
        };

        // Load user commands at initialization
        LoadUserCommands();

        // rndcode - custom encoder/decoder that produces highly random-looking codes but are reversible.
        // Usage:
        //   rndcode encode [--password <pw>] [--compress] <text>
        //   rndcode decode [--password <pw>] <code>
        BuiltInCommands["rndcode"] = async args =>
        {
            if (args.Length < 2) { Console.WriteLine("Usage: rndcode encode|decode [--password <pw>] [--compress] <text>"); await Task.CompletedTask; return; }
            try
            {
                var list = args.ToList();
                var mode = list[0].ToLowerInvariant();
                string password = null; bool compress = false;
                for (int i = 1; i < list.Count; i++)
                {
                    if (list[i] == "--password" && i + 1 < list.Count) { password = list[i + 1]; list[i] = null; list[i + 1] = null; i++; }
                    else if (list[i] == "--compress") { compress = true; list[i] = null; }
                }
                var remaining = list.Where(s => !string.IsNullOrEmpty(s)).Skip(1).ToArray();
                if (remaining.Length == 0) { Console.WriteLine("Missing text argument"); await Task.CompletedTask; return; }
                var text = string.Join(' ', remaining);

                string base64UrlEncode(byte[] data)
                {
                    var s = Convert.ToBase64String(data);
                    s = s.TrimEnd('='); s = s.Replace('+', '-').Replace('/', '_');
                    return s;
                }
                byte[] base64UrlDecode(string s)
                {
                    s = s.Replace('-', '+').Replace('_', '/');
                    int pad = (4 - s.Length % 4) % 4; s = s + new string('=', pad);
                    return Convert.FromBase64String(s);
                }

                byte[] CompressIfNeeded(byte[] input)
                {
                    if (!compress) return input;
                    using var ms = new MemoryStream(); using (var gz = new GZipStream(ms, CompressionLevel.Optimal, true)) { gz.Write(input, 0, input.Length); }
                    return ms.ToArray();
                }
                byte[] DecompressIfNeeded(byte[] input)
                {
                    try { using var inMs = new MemoryStream(input); using var gz = new GZipStream(inMs, CompressionMode.Decompress); using var outMs = new MemoryStream(); gz.CopyTo(outMs); return outMs.ToArray(); } catch { return input; }
                }

                if (mode == "encode")
                {
                    var plain = Encoding.UTF8.GetBytes(text);
                    var payload = CompressIfNeeded(plain);

                    // If password provided, encrypt payload using AES-GCM and include metadata
                    byte[] raw;
                    bool encrypted = false;
                    if (!string.IsNullOrEmpty(password))
                    {
                        encrypted = true;
                        var salt = new byte[16]; RandomNumberGenerator.Fill(salt);
                        using var kdf = new Rfc2898DeriveBytes(password, salt, 200_000, HashAlgorithmName.SHA256);
                        var key = kdf.GetBytes(32);
                        var nonce = new byte[12]; RandomNumberGenerator.Fill(nonce);
                        var cipher = new byte[payload.Length]; var tag = new byte[16];
                        using (var aesg = new AesGcm(key)) { aesg.Encrypt(nonce, payload, cipher, tag); }
                        // raw format: [ENCRYPTED(1)][salt(16)][nonce(12)][tag(16)][cipher]
                        using var ms = new MemoryStream(); ms.WriteByte(1); ms.Write(salt, 0, salt.Length); ms.Write(nonce, 0, nonce.Length); ms.Write(tag, 0, tag.Length); ms.Write(cipher, 0, cipher.Length); raw = ms.ToArray();
                        Array.Clear(key, 0, key.Length);
                    }
                    else
                    {
                        // raw: [ENCRYPTED(0)][payload]
                        using var ms = new MemoryStream(); ms.WriteByte(0); ms.Write(payload, 0, payload.Length); raw = ms.ToArray();
                    }

                    // base64url encode raw
                    var b64 = base64UrlEncode(raw);

                    // create short token (8 chars) used to deterministically insert noise
                    var tokenBytes = new byte[6]; RandomNumberGenerator.Fill(tokenBytes);
                    var token = BitConverter.ToString(tokenBytes).Replace("-", ""); // 12 hex chars

                    // determine noise parameters from token hash
                    byte[] tokenHash;
                    using (var sha = SHA256.Create()) tokenHash = sha.ComputeHash(Encoding.UTF8.GetBytes(token));
                    int N = 3 + (tokenHash[0] % 6); // 3..8 inserts
                    int L = 3 + (tokenHash[1] % 6); // 3..8 length
                    var alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_";

                    var M = b64.Length;
                    var sb = new StringBuilder(b64);

                    // compute positions relative to original length M
                    var positions = new List<int>();
                    for (int i = 0; i < N; i++)
                    {
                        using var sha = SHA256.Create(); var h = sha.ComputeHash(Encoding.UTF8.GetBytes(token + ":" + i));
                        var val = BitConverter.ToUInt32(h, 0); var pos = (int)(val % (uint)Math.Max(1, M)); positions.Add(pos);
                    }

                    // perform insertions in ascending i, inserting at pos + i*L
                    var outSb = new StringBuilder(b64);
                    for (int i = 0; i < N; i++)
                    {
                        int insertAt = positions[i] + i * L;
                        if (insertAt < 0) insertAt = 0; if (insertAt > outSb.Length) insertAt = outSb.Length;
                        // deterministic noise content derived from token+i
                        using var sha2 = SHA256.Create(); var h2 = sha2.ComputeHash(Encoding.UTF8.GetBytes(token + "#" + i));
                        var noise = new char[L]; for (int j = 0; j < L; j++) noise[j] = alphabet[h2[j] % alphabet.Length];
                        outSb.Insert(insertAt, new string(noise));
                    }

                    var final = "RC1" + token + outSb.ToString();
                    Console.WriteLine(final);
                    await Task.CompletedTask; return;
                }
                else if (mode == "decode")
                {
                    var code = text;
                    if (!code.StartsWith("RC1") || code.Length <= 3 + 12) { Console.WriteLine("Invalid rndcode format"); await Task.CompletedTask; return; }
                    var token = code.Substring(3, 12); var obf = code.Substring(15);
                    byte[] tokenHash;
                    using (var sha = SHA256.Create()) tokenHash = sha.ComputeHash(Encoding.UTF8.GetBytes(token));
                    int N = 3 + (tokenHash[0] % 6); int L = 3 + (tokenHash[1] % 6);
                    int F = obf.Length; int M = F - N * L; if (M < 0) { Console.WriteLine("Invalid code (too short)"); await Task.CompletedTask; return; }

                    // recompute positions
                    var positions = new List<int>();
                    for (int i = 0; i < N; i++) { using var sha = SHA256.Create(); var h = sha.ComputeHash(Encoding.UTF8.GetBytes(token + ":" + i)); var val = BitConverter.ToUInt32(h, 0); var pos = (int)(val % (uint)Math.Max(1, M)); positions.Add(pos); }

                    var sb = new StringBuilder(obf);
                    // remove inserted blocks in reverse order
                    for (int i = N - 1; i >= 0; i--)
                    {
                        int idx = positions[i] + i * L;
                        if (idx < 0) idx = 0; if (idx + L > sb.Length) { Console.WriteLine("Corrupt code"); await Task.CompletedTask; return; }
                        sb.Remove(idx, L);
                    }

                    var b64 = sb.ToString();
                    byte[] raw;
                    try { raw = base64UrlDecode(b64); }
                    catch { Console.WriteLine("Base64 decode failed"); await Task.CompletedTask; return; }

                    if (raw.Length < 1) { Console.WriteLine("Invalid payload"); await Task.CompletedTask; return; }
                    bool encrypted = raw[0] == 1;
                    byte[] payload;
                    if (encrypted)
                    {
                        if (raw.Length < 1 + 16 + 12 + 16) { Console.WriteLine("Invalid encrypted payload"); await Task.CompletedTask; return; }
                        var pos = 1;
                        var salt = raw.Skip(pos).Take(16).ToArray(); pos += 16;
                        var nonce = raw.Skip(pos).Take(12).ToArray(); pos += 12;
                        var tag = raw.Skip(pos).Take(16).ToArray(); pos += 16;
                        var cipher = raw.Skip(pos).ToArray();
                        if (string.IsNullOrEmpty(password)) { Console.Write("Password: "); password = Console.ReadLine(); }
                        using var kdf = new Rfc2898DeriveBytes(password, salt, 200_000, HashAlgorithmName.SHA256); var key = kdf.GetBytes(32);
                        var plain = new byte[cipher.Length];
                        try { using var aesg = new AesGcm(key); aesg.Decrypt(nonce, cipher, tag, plain); payload = plain; }
                        catch (Exception ex) { Console.WriteLine("Decryption failed: " + ex.Message); await Task.CompletedTask; return; }
                        finally { Array.Clear(key, 0, key.Length); }
                    }
                    else
                    {
                        payload = raw.Skip(1).ToArray();
                    }

                    var dec = DecompressIfNeeded(payload);
                    Console.WriteLine(Encoding.UTF8.GetString(dec));
                    await Task.CompletedTask; return;
                }
                else Console.WriteLine("Usage: rndcode encode|decode [--password <pw>] [--compress] <text>");
            }
            catch (Exception ex) { Console.WriteLine("tercode error: " + ex.Message); }
            await Task.CompletedTask;
        };

        // tercode - stronger encoder/decoder producing highly random-looking reversible codes.
        // Usage:
        //   tercode encode [--password <pw>] [--compress] <text>
        //   tercode decode [--password <pw>] <code>
        BuiltInCommands["tercode"] = async args =>
        {
            if (args.Length < 2) { Console.WriteLine("Usage: tercode encode|decode [--password <pw>] [--compress] [--base64] [--wrap] <text>"); await Task.CompletedTask; return; }
            try
            {
                var list = args.ToList();
                var mode = list[0].ToLowerInvariant();
                string password = null; bool compress = false; bool base64flag = false; bool wrap = false;
                int layers = 0;
                for (int i = 1; i < list.Count; i++)
                {
                    if (list[i] == "--password" && i + 1 < list.Count) { password = list[i + 1]; list[i] = null; list[i + 1] = null; i++; }
                    else if (list[i] == "--compress") { compress = true; list[i] = null; }
                    else if (list[i] == "--base64") { base64flag = true; list[i] = null; }
                    else if (list[i] == "--wrap") { wrap = true; list[i] = null; }
                    else if (list[i] == "--layers" && i + 1 < list.Count && int.TryParse(list[i + 1], out var lv)) { layers = Math.Max(0, lv); list[i] = null; list[i + 1] = null; i++; }
                }
                var remaining = list.Where(s => !string.IsNullOrEmpty(s)).Skip(1).ToArray();
                if (remaining.Length == 0) { Console.WriteLine("Missing text argument"); await Task.CompletedTask; return; }
                var text = string.Join(' ', remaining);

                static string Base64UrlEncode(byte[] data)
                {
                    var s = Convert.ToBase64String(data);
                    s = s.TrimEnd('='); s = s.Replace('+', '-').Replace('/', '_');
                    return s;
                }
                static byte[] Base64UrlDecode(string s)
                {
                    s = s.Replace('-', '+').Replace('_', '/');
                    int pad = (4 - s.Length % 4) % 4; s = s + new string('=', pad);
                    return Convert.FromBase64String(s);
                }

                byte[] CompressIfNeeded(byte[] input)
                {
                    if (!compress) return input;
                    using var ms = new MemoryStream(); using (var gz = new GZipStream(ms, CompressionLevel.Optimal, true)) { gz.Write(input, 0, input.Length); }
                    return ms.ToArray();
                }
