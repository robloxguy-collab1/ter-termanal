    // Read the OS ARP/neighbor table and return a map of ip -> mac (best-effort).
    static async Task<Dictionary<string,string>> GetArpTableAsync()
    {
        var map = new Dictionary<string,string>();
        try
        {
            if (RuntimeInformation.IsOSPlatform(OSPlatform.Windows))
            {
                // arp -a output
                var outp = await RunProcessCaptureOutputAsync("arp", "-a", 1500) ?? string.Empty;
                var lines = outp.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                var rx = new Regex(@"(?<ip>\d+\.\d+\.\d+\.\d+)\s+((?<mac>[0-9A-Fa-f\-:]{17})|(?<mac2>[0-9A-Fa-f]{2}-[0-9A-Fa-f]{2}-[0-9A-Fa-f]{2}-[0-9A-Fa-f]{2}-[0-9A-Fa-f]{2}-[0-9A-Fa-f]{2}))");
                foreach (var l in lines)
                {
                    var m = rx.Match(l);
                    if (m.Success)
                    {
                        var ip = m.Groups["ip"].Value.Trim();
                        var mac = (m.Groups["mac"].Success ? m.Groups["mac"].Value : (m.Groups["mac2"].Success ? m.Groups["mac2"].Value : null));
                        if (!string.IsNullOrEmpty(ip) && !string.IsNullOrEmpty(mac)) map[ip] = mac.Replace('-', ':').ToLowerInvariant();
                    }
                }
            }
            else
            {
                // try ip neigh (Linux) or arp -n fallback
                var outp = await RunProcessCaptureOutputAsync("ip", "neigh", 1500);
                if (!string.IsNullOrEmpty(outp))
                {
                    var lines = outp.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                    var rx = new Regex(@"(?<ip>\d+\.\d+\.\d+\.\d+).*lladdr\s+(?<mac>[0-9A-Fa-f:]{17})");
                    foreach (var l in lines)
                    {
                        var m = rx.Match(l);
                        if (m.Success) map[m.Groups["ip"].Value.Trim()] = m.Groups["mac"].Value.ToLowerInvariant();
                    }
                }
                if (map.Count == 0)
                {
                    var outp2 = await RunProcessCaptureOutputAsync("arp", "-n", 1200) ?? string.Empty;
                    var lines2 = outp2.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                    var rx2 = new Regex(@"(?<ip>\d+\.\d+\.\d+\.\d+)\s+.*?(?<mac>[0-9A-Fa-f:]{17})");
                    foreach (var l in lines2)
                    {
                        var m = rx2.Match(l);
                        if (m.Success) map[m.Groups["ip"].Value.Trim()] = m.Groups["mac"].Value.ToLowerInvariant();
                    }
                }
            }
        }
        catch { }
        return map;
    }

