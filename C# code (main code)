        // tlsinfo <host> [port] - retrieve TLS certificate info (connects to host:port)
        BuiltInCommands["tlsinfo"] = async args =>
        {
            if (args.Length == 0) { Console.WriteLine("Usage: tlsinfo <host|url> [port]"); await Task.CompletedTask; return; }
            try
            {
                string input = args[0];
                string host; int port = -1;
                if (input.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || input.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
                {
                    var u = new Uri(input);
                    host = u.Host; port = u.Port;
                    if (port == -1) port = u.Scheme.Equals("https", StringComparison.OrdinalIgnoreCase) ? 443 : 80;
                }
                else if (input.IndexOf(':') > 0 && IPAddress.TryParse(input.Split(':')[0], out _))
                {
                    var parts = input.Split(':'); host = parts[0]; int.TryParse(parts[1], out port);
                }
                else
                {
                    host = input; port = 443;
                }
                if (args.Length > 1) int.TryParse(args[1], out port);

                using var tcp = new TcpClient();
                await tcp.ConnectAsync(host, port);
                using var stream = tcp.GetStream();
                using var ssl = new SslStream(stream, false, (sender, cert, chain, errs) => true);
                await ssl.AuthenticateAsClientAsync(host);
                var cert = ssl.RemoteCertificate as X509Certificate2 ?? new X509Certificate2(ssl.RemoteCertificate);
                Console.WriteLine($"Subject: {cert.Subject}");
                Console.WriteLine($"Issuer: {cert.Issuer}");
                Console.WriteLine($"Thumbprint: {cert.Thumbprint}");
                Console.WriteLine($"NotBefore: {cert.NotBefore}");
                Console.WriteLine($"NotAfter: {cert.NotAfter}");
                Console.WriteLine($"SignatureAlgorithm: {cert.SignatureAlgorithm.FriendlyName}");
            }
            catch (Exception ex) { Console.WriteLine("tlsinfo error: " + ex.Message); }
            await Task.CompletedTask;
        };

        // scan <host|local> [ports] - improved scanner: resolves host, shows IP(s), reverse dns, attempts banner grabs.
        // If target is 'local', 'in', 'lan', 'network' or omitted the command will discover other hosts on the local /24 and scan them.
        BuiltInCommands["scan"] = async args =>
        {
            try
            {
                // support flag --allow-external to permit scanning non-private/public addresses (must be explicit)
                var argList = args.ToList();
                bool allowExternal = false;
                for (int i = argList.Count - 1; i >= 0; i--) if (argList[i].Equals("--allow-external", StringComparison.OrdinalIgnoreCase)) { allowExternal = true; argList.RemoveAt(i); }

                string targetArg = argList.Count > 0 ? argList[0] : "local";
                string portsArg = argList.Count > 1 ? argList[1] : "22,80,443,3389,3306,8080,53,21,25,445";

                var doSubnetScan = new[] { "local", "in", "lan", "network", "subnet", "", "all", "allnets", "networks" };
                var allNetsKeys = new[] { "all", "allnets", "networks" };

                // If user asked to scan all local networks, enumerate all interfaces and perform a limited sweep per network.
                if (allNetsKeys.Contains(targetArg.ToLowerInvariant()))
                {
                    Console.WriteLine("WARNING: This will scan all local networks discovered on this machine. Ensure you have authorization.");
                    Console.Write("Proceed? (y/N): ");
                    var ok = Console.ReadLine(); if (string.IsNullOrEmpty(ok) || !ok.Trim().StartsWith("y", StringComparison.OrdinalIgnoreCase)) { Console.WriteLine("Aborted."); await Task.CompletedTask; return; }

                    int perSubnetMax = 128; // default limit per subnet
                    if (argList.Count > 1 && int.TryParse(argList[1], out var pm)) perSubnetMax = Math.Min(1024, Math.Max(4, pm));

                    // ports to scan (from args or default)
                    var portsArgAll = argList.Count > 2 ? argList[2] : "22,80,443,3389,3306,8080,53,21,25,445";
                    var portsAll = new List<int>();
                    foreach (var token in portsArgAll.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    {
                        var t = token.Trim();
                        if (t.Contains('-'))
                        {
                            var p = t.Split('-', 2);
                            if (int.TryParse(p[0], out var a) && int.TryParse(p[1], out var b)) { for (int j = Math.Min(a,b); j <= Math.Max(a,b); j++) portsAll.Add(j); }
                        }
                        else if (int.TryParse(t, out var p)) portsAll.Add(p);
                    }
                    portsAll = portsAll.Distinct().Where(p => p >= 1 && p <= 65535).OrderBy(p => p).ToList();
                    if (portsAll.Count == 0) { Console.WriteLine("No ports to scan."); await Task.CompletedTask; return; }

                    var interfaces = NetworkInterface.GetAllNetworkInterfaces().Where(ni => ni.OperationalStatus == OperationalStatus.Up);
                    var subnets = new List<string>();
                    foreach (var ni in interfaces)
                    {
                        try
                        {
                            foreach (var ua in ni.GetIPProperties().UnicastAddresses)
                            {
                                if (ua.Address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork && !IPAddress.IsLoopback(ua.Address))
                                {
                                    var parts = ua.Address.ToString().Split('.');
                                    if (parts.Length == 4)
                                    {
                                        var prefix = string.Join('.', parts.Take(3)) + ".";
                                        if (!subnets.Contains(prefix)) subnets.Add(prefix);
                                    }
                                }
                            }
                        }
                        catch { }
                    }

                    if (subnets.Count == 0) { Console.WriteLine("No IPv4 subnets found."); await Task.CompletedTask; return; }
                    Console.WriteLine($"Discovered subnets: {string.Join(',', subnets)}");

                    var globalUp = new List<string>();
                    var pingSem = new System.Threading.SemaphoreSlim(200);
                    var pingTasks = new List<Task>();
                    foreach (var prefix in subnets)
                    {
                        int max = perSubnetMax;
                        for (int i = 1; i <= max; i++)
                        {
                            var ip = prefix + i;
                            await pingSem.WaitAsync();
                            pingTasks.Add(Task.Run(async () =>
                            {
                                try { using var p = new Ping(); var r = await p.SendPingAsync(ip, 300); if (r.Status == IPStatus.Success) lock (globalUp) { globalUp.Add(ip); } }
                                catch { }
                                finally { pingSem.Release(); }
                            }));
                        }
                    }
                    await Task.WhenAll(pingTasks);
                    // augment hosts with entries in the ARP/neighbor table to catch devices that drop ICMP
                    try
                    {
                        var arp = await GetArpTableAsync();
                        foreach (var ip in arp.Keys)
                        {
                            if (!globalUp.Contains(ip)) globalUp.Add(ip);
                        }
                    }
                    catch { }
                    globalUp = globalUp.OrderBy(x => x).ToList();
                    Console.WriteLine($"Hosts up across networks: {string.Join(',', globalUp)}");

                    if (globalUp.Count == 0) { Console.WriteLine("No hosts found up on local networks."); await Task.CompletedTask; return; }

                    var hostSem = new System.Threading.SemaphoreSlim(30);
                    var hostTasks = new List<Task>();
                    var wellKnown = new Dictionary<int,string> { [22] = "ssh", [80] = "http", [443] = "https", [3389] = "rdp", [3306] = "mysql", [8080] = "http-alt", [53] = "dns", [21] = "ftp", [25] = "smtp", [445] = "microsoft-ds" };
                    var arpMap = new Dictionary<string,string>();
                    try { arpMap = await GetArpTableAsync(); } catch { }

                    foreach (var h in globalUp)
                    {
                        await hostSem.WaitAsync();
                        hostTasks.Add(Task.Run(async () =>
                        {
                            try
                            {
                                // attempt to resolve a friendly device name (reverse DNS, NetBIOS/mDNS fallbacks)
                                string devNameAll = null;
                                try { var heAll = await Dns.GetHostEntryAsync(h); if (!string.IsNullOrEmpty(heAll?.HostName)) devNameAll = heAll.HostName; } catch { }
                                try { if (string.IsNullOrEmpty(devNameAll)) devNameAll = await ResolveFriendlyNameAsync(h); } catch { }
                                arpMap.TryGetValue(h, out var macAll);
                                Console.WriteLine($"\nHost: {h}{(string.IsNullOrEmpty(devNameAll) ? "" : " (" + devNameAll + ")")}{(string.IsNullOrEmpty(macAll) ? "" : " MAC: " + macAll)} ");
                                foreach (var port in portsAll)
                                {
                                    try
                                    {
                                        using var tc = new TcpClient();
                                        var conn = tc.ConnectAsync(h, port);
                                        var comp = await Task.WhenAny(conn, Task.Delay(500));
                                        if (comp == conn && tc.Connected)
                                        {
                                            Console.Write($"  {port}: open"); if (wellKnown.TryGetValue(port, out var svc)) Console.Write($" ({svc})"); Console.WriteLine();
                                        }
                                    }
                                    catch { }
                                }
                            }
                            finally { hostSem.Release(); }
                        }));
                    }
                    await Task.WhenAll(hostTasks);
                    await Task.CompletedTask; return;
                }
                if (doSubnetScan.Contains(targetArg.ToLowerInvariant()))
                {
                    // find local IPv4 and IPv6 addresses
                    string localV4 = null;
                    var localV6 = new List<IPAddress>();
                    foreach (var ni in NetworkInterface.GetAllNetworkInterfaces())
                    {
                        if (ni.OperationalStatus != OperationalStatus.Up) continue;
                        foreach (var ua in ni.GetIPProperties().UnicastAddresses)
                        {
                            if (ua.Address.IsIPv4MappedToIPv6) continue;
                            if (ua.Address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork && !IPAddress.IsLoopback(ua.Address)) { localV4 ??= ua.Address.ToString(); }
                            if (ua.Address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetworkV6 && !IPAddress.IsLoopback(ua.Address)) localV6.Add(ua.Address);
                        }
                        if (localV4 != null || localV6.Count > 0) break;
                    }
                    if (localV4 == null && localV6.Count == 0) { Console.WriteLine("No local IP addresses found."); await Task.CompletedTask; return; }

                    if (localV4 != null)
                    {
                        // Determine all connected IPv4 subnets from active interfaces
                        var prefixes = new List<string>();
                        foreach (var ni in NetworkInterface.GetAllNetworkInterfaces().Where(n => n.OperationalStatus == OperationalStatus.Up))
                        {
                            try
                            {
                                foreach (var ua in ni.GetIPProperties().UnicastAddresses)
                                {
                                    if (ua.Address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork && !IPAddress.IsLoopback(ua.Address))
                                    {
                                        var parts = ua.Address.ToString().Split('.');
                                        if (parts.Length == 4)
                                        {
                                            var prefix = string.Join('.', parts.Take(3)) + ".";
                                            if (!prefixes.Contains(prefix)) prefixes.Add(prefix);
                                        }
                                    }
                                }
                            }
                            catch { }
                        }
                        if (prefixes.Count == 0) { Console.WriteLine("No IPv4 subnets found."); await Task.CompletedTask; return; }

                        int perSubnetMax = 64; // default per-subnet sweep
                        if (argList.Count > 1 && int.TryParse(argList[1], out var m)) perSubnetMax = Math.Min(254, Math.Max(4, m));
                        Console.WriteLine($"Scanning connected IPv4 subnets: {string.Join(',', prefixes)} (ping sweep + port scan, up to {perSubnetMax} hosts per subnet)...");

                        // parse portsArg
                        var ports = new List<int>();
                        foreach (var token in portsArg.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            var t = token.Trim();
                            if (t.Contains('-'))
                            {
                                var p = t.Split('-', 2);
                                if (int.TryParse(p[0], out var a) && int.TryParse(p[1], out var b)) { for (int j = Math.Min(a,b); j <= Math.Max(a,b); j++) ports.Add(j); }
                            }
                            else if (int.TryParse(t, out var p)) ports.Add(p);
                        }
                        ports = ports.Distinct().Where(p => p >= 1 && p <= 65535).OrderBy(p => p).ToList();
                        if (ports.Count == 0) { Console.WriteLine("No ports to scan."); await Task.CompletedTask; return; }

                        var wellKnown = new Dictionary<int,string> { [22] = "ssh", [80] = "http", [443] = "https", [3389] = "rdp", [3306] = "mysql", [8080] = "http-alt", [53] = "dns", [21] = "ftp", [25] = "smtp", [445] = "microsoft-ds" };

                        var globalUp = new List<string>();
                        var pingSem = new System.Threading.SemaphoreSlim(200);
                        var pingTasks = new List<Task>();
                        foreach (var prefix in prefixes)
                        {
                            int max = perSubnetMax;
                            for (int i = 1; i <= max; i++)
                            {
                                var ip = prefix + i;
                                await pingSem.WaitAsync();
                                pingTasks.Add(Task.Run(async () =>
                                {
                                    try { using var p = new Ping(); var r = await p.SendPingAsync(ip, 300); if (r.Status == IPStatus.Success) lock (globalUp) { globalUp.Add(ip); } }
                                    catch { }
                                    finally { pingSem.Release(); }
                                }));
                            }
                        }
                        await Task.WhenAll(pingTasks);
                    // augment hosts with ARP/neighbour entries to improve accuracy for hosts that block ICMP
                    try
                    {
