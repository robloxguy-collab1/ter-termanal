    static string FindRunScriptInFolder(string folder)
    {
        // Preferred names first
        var candidates = new[] { "run", "run.sh", "run.bat", "run.cmd", "run.ps1", "run.exe" };
        foreach (var c in candidates)
        {
            var p = Path.Combine(folder, c);
            if (File.Exists(p)) return p;
        }
        // fall back to any executable-ish file
        var exts = new[] { ".sh", ".py", ".ps1", ".exe", ".bat", ".cmd" };
        foreach (var f in Directory.GetFiles(folder))
        {
            var e = Path.GetExtension(f).ToLowerInvariant();
            if (exts.Contains(e)) return f;
        }
        // last resort: any file (maybe script without ext)
        var any = Directory.GetFiles(folder).FirstOrDefault();
        return any;
    }

    static string QuoteArg(string s)
    {
        if (string.IsNullOrEmpty(s)) return "\"\"";
        if (RuntimeInformation.IsOSPlatform(OSPlatform.Windows))
        {
            if (s.Contains(' ')) return "\"" + s + "\"";
            return s;
        }
        // for unix shells, single-quote and escape single quotes inside
        if (!s.Contains('\'')) return "'" + s + "'";
        return '"' + s.Replace("\"", "\\\"") + '"';
