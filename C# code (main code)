                    catch { }
                    globalUp = globalUp.OrderBy(x => x).ToList();
                        Console.WriteLine($"IPv4 hosts up: {string.Join(',', globalUp)}");

                        if (globalUp.Count == 0) { Console.WriteLine("No hosts found up on local networks."); await Task.CompletedTask; return; }

                        // scan each up host, limited parallelism, and attempt to resolve device name
                        var hostSem = new System.Threading.SemaphoreSlim(10);
                        var hostTasks = new List<Task>();
                        foreach (var h in globalUp)
                        {
                            await hostSem.WaitAsync();
                            hostTasks.Add(Task.Run(async () =>
                            {
                                try
                                {
                                    string devName = null;
                                    try { var he = await Dns.GetHostEntryAsync(h); if (!string.IsNullOrEmpty(he?.HostName)) devName = he.HostName; } catch { }
                                    try { if (string.IsNullOrEmpty(devName)) devName = await ResolveFriendlyNameAsync(h); } catch { }
                                    var arpMapLocal = new Dictionary<string,string>(); try { arpMapLocal = await GetArpTableAsync(); } catch { }
                                    arpMapLocal.TryGetValue(h, out var mac);
                                    Console.WriteLine($"\nHost: {h}{(string.IsNullOrEmpty(devName) ? "" : " (" + devName + ")")}{(string.IsNullOrEmpty(mac) ? "" : " MAC: " + mac)} ");
                                    foreach (var port in ports)
                                    {
                                        try
                                        {
                                            using var tc = new TcpClient();
                                            var conn = tc.ConnectAsync(h, port);
                                            var comp = await Task.WhenAny(conn, Task.Delay(500));
                                            if (comp == conn && tc.Connected)
                                            {
                                                Console.Write($"  {port}: open"); if (wellKnown.TryGetValue(port, out var svc)) Console.Write($" ({svc})"); Console.WriteLine();
                                                try
                                                {
                                                    using var ns = tc.GetStream();
                                                    ns.ReadTimeout = 500; ns.WriteTimeout = 500;
                                                    if (port == 80 || port == 8080 || port == 8000)
                                                    {
                                                        var probe = Encoding.ASCII.GetBytes("HEAD / HTTP/1.0\r\nHost: " + h + "\r\n\r\n");
                                                        await ns.WriteAsync(probe, 0, probe.Length);
                                                        var buf = new byte[512];
                                                        var readTask = ns.ReadAsync(buf, 0, buf.Length);
                                                        var rcomp = await Task.WhenAny(readTask, Task.Delay(500));
                                                        if (rcomp == readTask && readTask.Result > 0)
                                                        {
                                                            var txt = Encoding.UTF8.GetString(buf, 0, readTask.Result);
                                                            var firstLine = txt.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";
                                                            Console.WriteLine("  banner: " + (firstLine.Length>200? firstLine.Substring(0,200)+"...": firstLine));
                                                        }
                                                    }
                                                }
                                                catch { }
                                            }
