                    var sources = coords.Select(c => c.src).Distinct().ToList();
                    if (coords.Count == 0) return (null, null, double.NaN, sources);

                    // compute weighted robust average and an accuracy estimate
                    double ToRad(double x) => x * Math.PI / 180.0;
                    double DistKm((double lat, double lon) a, (double lat, double lon) b)
                    {
                        var R = 6371.0;
                        var dLat = ToRad(b.lat - a.lat);
                        var dLon = ToRad(b.lon - a.lon);
                        var lat1 = ToRad(a.lat); var lat2 = ToRad(b.lat);
                        var aa = Math.Pow(Math.Sin(dLat / 2), 2) + Math.Cos(lat1) * Math.Cos(lat2) * Math.Pow(Math.Sin(dLon / 2), 2);
                        var c = 2 * Math.Atan2(Math.Sqrt(aa), Math.Sqrt(1 - aa));
                        return R * c;
                    }

                    var totalW = coords.Sum(c => c.weight);
                    var weightedLat = coords.Sum(c => c.lat * c.weight) / totalW;
                    var weightedLon = coords.Sum(c => c.lon * c.weight) / totalW;

                    // compute distances of each point to weighted center
                    var dists = coords.Select(c => DistKm((c.lat, c.lon), (weightedLat, weightedLon))).ToList();
                    // remove extreme outliers (beyond 3x median)
                    var med = dists.OrderBy(x => x).ElementAt(dists.Count / 2);
                    var filteredIdx = dists.Select((d, i) => new { d, i }).Where(x => x.d <= Math.Max(med * 3.0, 200.0)).Select(x => x.i).ToList();
                    if (filteredIdx.Count > 0 && filteredIdx.Count < coords.Count)
                    {
                        var fw = filteredIdx.Sum(i => coords[i].weight);
                        weightedLat = filteredIdx.Sum(i => coords[i].lat * coords[i].weight) / fw;
                        weightedLon = filteredIdx.Sum(i => coords[i].lon * coords[i].weight) / fw;
                        dists = filteredIdx.Select(i => DistKm((coords[i].lat, coords[i].lon), (weightedLat, weightedLon))).ToList();
                    }

                    // accuracy estimate: use RMS distance as approx uncertainty
                    double rms = Math.Sqrt(dists.Average(x => x * x));
                    // if only one source, be conservative
                    if (coords.Count == 1) rms = Math.Max(rms, 50.0);

                    return (weightedLat, weightedLon, rms, sources);
